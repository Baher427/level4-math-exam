// This is your Prisma schema file,
// learn more about it in docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

// جلسة امتحان كاملة
model ExamSession {
  id          String   @id @default(cuid())
  studentName String?  // اسم الطالب (اختياري)
  
  // النتيجة الإجمالية
  totalQuestions Int      @default(40)
  correctAnswers Int     @default(0)
  percentage     Float    @default(0)
  
  // الوقت
  totalTimeSeconds Int   @default(0)  // الوقت الكلي بالثواني
  
  // حالة الامتحان
  status        String   @default("completed") // completed, abandoned
  
  // تاريخ الامتحان
  startedAt    DateTime @default(now())
  finishedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  
  // العلاقات
  answers ExamAnswer[]
}

// إجابة سؤال واحد
model ExamAnswer {
  id            String   @id @default(cuid())
  examSessionId String
  
  // معلومات السؤال
  section       String   // الضرب, Abacus1, Abacus2, Mental, Additional
  questionIndex Int       // رقم السؤال في القسم
  globalIndex   Int       // رقم السؤال الكلي (1-40)
  
  // السؤال والإجابة
  questionData  String   // بيانات السؤال (JSON)
  userAnswer    String?   // إجابة المستخدم
  correctAnswer Int      // الإجابة الصحيحة
  
  // النتيجة
  isCorrect     Boolean  @default(false)
  
  // الوقت
  timeSeconds   Int      @default(0)  // الوقت المستغرق في هذا السؤال
  
  // هل تم تعليم السؤال
  isMarked       Boolean  @default(false)
  
  createdAt     DateTime @default(now())
  
  // العلاقات
  examSession ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
}
