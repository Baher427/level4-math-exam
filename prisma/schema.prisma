datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// جلسة امتحان كاملة
model ExamSession {
  id String @id @default(uuid())
  
  studentName String?
  
  // النتيجة الإجمالية
  totalQuestions Int @default(40)
  correctAnswers Int @default(0)
  percentage     Float @default(0)
  
  // الوقت
  totalTimeSeconds Int @default(0)
  
  // حالة الامتحان
  status String @default("completed")
  
  // التواريخ
  startedAt  DateTime @default(now())
  finishedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  
  // العلاقات
  answers ExamAnswer[]
  
  @@index([createdAt(sort: Desc)])
  @@map("exam_sessions")
}

// إجابة سؤال واحد
model ExamAnswer {
  id String @id @default(uuid())
  
  examSessionId String
  examSession   ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  
  // معلومات السؤال
  section       String
  questionIndex Int
  globalIndex   Int
  
  // السؤال والإجابة
  questionData  String
  userAnswer    String?
  correctAnswer Int
  
  // النتيجة
  isCorrect Boolean @default(false)
  
  // الوقت
  timeSeconds Int @default(0)
  
  // تعليم السؤال
  isMarked Boolean @default(false)
  
  createdAt DateTime @default(now())
  
  @@index([examSessionId])
  @@index([globalIndex])
  @@map("exam_answers")
}
